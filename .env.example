# Runtime environment: production | staging | development (default: development)
# Controls OTel defaults: production/staging enable it; development disables it unless overridden.
ENVIRONMENT=development

# Required
DISCORD_TOKEN=your_discord_bot_token
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret
REDIS_URL=redis://localhost:6379

# Observability (OpenTelemetry)
# OTel is auto-enabled for production/staging and auto-disabled for development.
# Set explicitly to override the environment default.
OTEL_SDK_DISABLED=false
OTEL_SERVICE_NAME=discord-music-bot
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
