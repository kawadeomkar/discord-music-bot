# Runtime environment name — defaults to the current git branch (main → production).
# Set explicitly in environments without a git checkout (Docker, CI).
ENVIRONMENT=development

# Required
DISCORD_TOKEN=your_discord_bot_token
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret
REDIS_URL=redis://localhost:6379

# Optional — where the bgutil PO-token provider sidecar listens (docker-compose
# service `bgutil-pot-provider`). The default matches the plugin's built-in default;
# only set this when the provider lives somewhere other than localhost:4416.
# POT_PROVIDER_URL=http://127.0.0.1:4416

# Observability (OpenTelemetry)
OTEL_SDK_DISABLED=false
OTEL_SERVICE_NAME=discord-music-bot
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
