# Runtime environment name — defaults to the current git branch (main → production).
# Set explicitly in environments without a git checkout (Docker, CI).
ENVIRONMENT=development

# Required
DISCORD_TOKEN=your_discord_bot_token
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret
REDIS_URL=redis://localhost:6379

# Postgres play-history archive (docs/POSTGRES_HISTORY_PLAN.md) — OPTIONAL.
# docker-compose interpolates these into the postgres service AND builds the
# bot's POSTGRES_URL from them, so the password lives here only. USER/DB default
# to "musicbot" if unset; PASSWORD is required to bring the stack up.
# Leave the whole block unset to run without the archive.
POSTGRES_USER=musicbot
POSTGRES_PASSWORD=change_me
POSTGRES_DB=musicbot
# Running the bot outside compose (poetry run bot)? compose won't build the URL
# for you — set it explicitly instead:
# POSTGRES_URL=postgresql://musicbot:change_me@127.0.0.1:5432/musicbot

# Optional — where the bgutil PO-token provider sidecar listens (docker-compose
# service `bgutil-pot-provider`). The default matches the plugin's built-in default;
# only set this when the provider lives somewhere other than localhost:4416.
# POT_PROVIDER_URL=http://127.0.0.1:4416

# Observability (OpenTelemetry)
OTEL_SDK_DISABLED=false
OTEL_SERVICE_NAME=discord-music-bot
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
